    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = merge(
    var.tags,
    {
      Name = "${var.project_name}-${var.environment}-efs-sg"
    }
  )

  lifecycle {
    create_before_destroy = true
  }
}
